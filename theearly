RunService.RenderStepped:Connect(function()
    if State.TriggerBot.Enabled then
        if State.TriggerBot.TargetLockOnly and not State.TargetLock.Enabled then
            return
        end

        local shouldTrigger = false
        if State.TriggerBot.ActivationMode == "Always" then
            shouldTrigger = true
        elseif State.TriggerBot.ActivationMode == "Hold" and TriggerBotActive then
            shouldTrigger = true
        elseif State.TriggerBot.ActivationMode == "Toggle" and TriggerBotActive then
            shouldTrigger = true
        end

        if shouldTrigger and tick() - lastTrigger > State.TriggerBot.Cooldown then
            local target = GetClosestPlayer(State.TriggerBot.Distance, "HumanoidRootPart")
            if target and IsPlayerValidTarget(target) then
                pcall(function()
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                    task.wait(0.01)
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                end)
                lastTrigger = tick()
            end
        end
    end
end)


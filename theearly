RunService.RenderStepped:Connect(function()
    if State.TargetLock.Enabled and State.TargetLock.SelectedPlayer and State.TargetLock.SelectedPlayer.Character then
        local plr = State.TargetLock.SelectedPlayer
        local char = plr.Character
        local head = char:FindFirstChild("Head")
        local hrp = char:FindFirstChild("HumanoidRootPart")

        if head and hrp and Executor.HasDrawing then
            CreateTargetESP(plr)
            local espData = TargetESPObjects[plr]
            local pos, onScreen = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 1.2, 0))

            if onScreen then
                espData.Name.Visible = true
                espData.Name.Position = Vector2.new(pos.X, pos.Y)
                espData.Name.Text = "@" .. plr.Name .. " [LOCKED]"
                espData.Name.Color = Colors.BloodRed
            else
                espData.Name.Visible = false
            end
        end
    else
        for plr, _ in pairs(TargetESPObjects) do
            RemoveTargetESP(plr)
        end
    end
end)


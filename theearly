-- ═══════════════════════════════════════════════════════════════════════════════
--  SAFE WRAPPER FUNCTIONS
-- ═══════════════════════════════════════════════════════════════════════════════
local function SafeCall(func, ...)
    if type(func) ~= "function" then return nil end
    local s, r = pcall(func, ...)
    if s then return r end
    return nil
end

local function SafeFindFirstChild(parent, name)
    if not parent or typeof(parent) ~= "Instance" then return nil end
    local s, r = pcall(function() return parent:FindFirstChild(name) end)
    if s and r then return r end
    return nil
end

local function SafeFindFirstChildOfClass(parent, className)
    if not parent or typeof(parent) ~= "Instance" then return nil end
    local s, r = pcall(function() return parent:FindFirstChildOfClass(className) end)
    if s and r then return r end
    return nil
end

local function SafeGetChildren(parent)
    if not parent or typeof(parent) ~= "Instance" then return {} end
    local s, r = pcall(function() return parent:GetChildren() end)
    if s and r then return r end
    return {}
end

local function SafeGetDescendants(parent)
    if not parent or typeof(parent) ~= "Instance" then return {} end
    local s, r = pcall(function() return parent:GetDescendants() end)
    if s and r then return r end
    return {}
end

local function SafeDisconnect(conn)
    if conn and typeof(conn) == "RBXScriptConnection" then
        pcall(function() conn:Disconnect() end)
    end
end

local function SafeDestroy(obj)
    if obj and typeof(obj) == "Instance" then
        pcall(function() obj:Destroy() end)
    end
end

-- ═══════════════════════════════════════════════════════════════════════════════
--  UTILITY FUNCTIONS
-- ═══════════════════════════════════════════════════════════════════════════════
local function Round(num, decimals)
    decimals = decimals or 0
    local mult = 10 ^ decimals
    return math.floor(num * mult + 0.5) / mult
end

local function FormatNumber(num)
    return tostring(Round(num, 3))
end

local function CreateInstance(className, properties)
    local s, obj = pcall(function()
        return Instance.new(className)
    end)
    if not s or not obj then return nil end
    for prop, value in pairs(properties or {}) do
        if prop ~= "Parent" then
            pcall(function() obj[prop] = value end)
        end
    end
    if properties and properties.Parent then
        pcall(function() obj.Parent = properties.Parent end)
    end
    return obj
end


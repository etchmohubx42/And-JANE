-- Target Lock Logic
local function GetPlayerUnderMouse()
    local mousePos = UserInputService:GetMouseLocation()
    local ray = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
    local result = workspace:Raycast(ray.Origin, ray.Direction * 1000)
    if result then
        local model = result.Instance:FindFirstAncestorOfClass("Model")
        if model then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Character == model and plr ~= LocalPlayer then
                    return plr
                end
            end
        end
    end
    return nil
end

TargetLockBtn.MouseButton1Click:Connect(function()
    local target = GetPlayerUnderMouse()
    if target then
        if State.TargetLock.SelectedPlayer == target then
            State.TargetLock.SelectedPlayer = nil
            State.TargetLock.SelectedPlayerName = ""
            State.TargetLock.Enabled = false
            TargetLockIndicator.Visible = false
            TargetNameLabel.Visible = false
            TargetLockBtn.ImageColor3 = Colors.Accent
        else
            State.TargetLock.SelectedPlayer = target
            State.TargetLock.SelectedPlayerName = "@" .. target.Name
            State.TargetLock.Enabled = true
            TargetLockIndicator.Visible = true
            TargetNameLabel.Text = "@" .. target.Name
            TargetNameLabel.Visible = true
            TargetLockBtn.ImageColor3 = Colors.Red
        end
    else

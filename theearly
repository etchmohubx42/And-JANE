    {type="input", text="Target Player", default="", callback=function(v)
        if v and v ~= "" then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Name:lower():find(v:lower()) or plr.DisplayName:lower():find(v:lower()) then
                    State.Teleport.SelectedPlayer = plr
                    break
                end
            end
        end
    end},
    {type="button", text="Teleport To Player", callback=function()
        if State.Teleport.SelectedPlayer and State.Teleport.SelectedPlayer.Character then
            local hrp = State.Teleport.SelectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp and myHrp then
                myHrp.CFrame = hrp.CFrame * CFrame.new(0, 0, State.Teleport.TeleportDistance)
            end
        end
    end},
    {type="button", text="Teleport Behind", callback=function()
        if State.Teleport.SelectedPlayer and State.Teleport.SelectedPlayer.Character then
            local hrp = State.Teleport.SelectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp and myHrp then
                myHrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -State.Teleport.TeleportDistance)
            end
        end
    end},
    {type="header", text="LOCATIONS"},
    {type="button", text="Teleport To Spawn", callback=function()
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local spawnLoc = workspace:FindFirstChild("SpawnLocation")
            if spawnLoc then
                LocalPlayer.Character.HumanoidRootPart.CFrame = spawnLoc.CFrame + Vector3.new(0, 5, 0)
            end
        end
    end},
    {type="button", text="Teleport To Safe Zone", callback=function()
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then

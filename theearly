-- ═══════════════════════════════════════════════════════════════════════════════
local ESPObjects = {}

local function CreateESPForPlayer(plr)
    if ESPObjects[plr] then return end
    local espData = { Box = nil, Name = nil, Health = nil, Distance = nil, SnapLine = nil }

    if Executor.HasDrawing then
        espData.Box = Drawing.new("Square")
        espData.Box.Visible = false
        espData.Box.Thickness = 1
        espData.Box.Color = Colors.Accent
        espData.Box.Filled = false

        espData.Name = Drawing.new("Text")
        espData.Name.Visible = false
        espData.Name.Size = 13
        espData.Name.Color = Colors.White
        espData.Name.Center = true
        espData.Name.Outline = true

        espData.Health = Drawing.new("Text")
        espData.Health.Visible = false
        espData.Health.Size = 11
        espData.Health.Color = Colors.Green
        espData.Health.Center = true
        espData.Health.Outline = true

        espData.Distance = Drawing.new("Text")
        espData.Distance.Visible = false
        espData.Distance.Size = 11
        espData.Distance.Color = Colors.Yellow
        espData.Distance.Center = true
        espData.Distance.Outline = true

        espData.SnapLine = Drawing.new("Line")
        espData.SnapLine.Visible = false
        espData.SnapLine.Thickness = 1
        espData.SnapLine.Color = Colors.Accent
    end
    ESPObjects[plr] = espData
end

local function RemoveESPForPlayer(plr)
    if ESPObjects[plr] then
        if Executor.HasDrawing then
            for _, obj in pairs(ESPObjects[plr]) do
                if obj and obj.Remove then obj:Remove() end
            end
        end
        ESPObjects[plr] = nil
    end
end

RunService.RenderStepped:Connect(function()
    if not State.ESP.Enabled and not State.Visual.ESPBox then
        for plr, _ in pairs(ESPObjects) do RemoveESPForPlayer(plr) end
        return
    end

    local camera = workspace.CurrentCamera
    local myChar = LocalPlayer.Character
    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local char = plr.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            local humanoid = char:FindFirstChildOfClass("Humanoid")

            if hrp and head and Executor.HasDrawing then
                CreateESPForPlayer(plr)
                local espData = ESPObjects[plr]
                local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
                local legPos = camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
                local dist = myHrp and (hrp.Position - myHrp.Position).Magnitude or 0

                if State.Visual.LimitDistance and dist > State.Visual.LimitDistanceValue then onScreen = false end

                if onScreen then
                    local boxHeight = math.abs(headPos.Y - legPos.Y)
                    local boxWidth = boxHeight * 0.6

                    if State.Visual.ESPBox then
                        espData.Box.Visible = true
                        espData.Box.Size = Vector2.new(boxWidth, boxHeight)
                        espData.Box.Position = Vector2.new(pos.X - boxWidth / 2, pos.Y - boxHeight / 2)
                        espData.Box.Filled = State.Visual.ESPFilled
                        espData.Box.Transparency = State.Visual.ESPFilled and 0.3 or 1
                    else
                        espData.Box.Visible = false
                    end

                    if State.Visual.ESPName or State.ESP.Names then
                        espData.Name.Visible = true
                        espData.Name.Position = Vector2.new(pos.X, headPos.Y - 15)
                        espData.Name.Text = plr.DisplayName ~= plr.Name and plr.DisplayName .. " [" .. plr.Name .. "]" or plr.Name
                        espData.Name.Color = State.ESP.Names and State.ESP.NameColor or Colors.White
                    else
                        espData.Name.Visible = false
                    end

                    if State.Visual.ESPHealth and humanoid then
                        espData.Health.Visible = true
                        espData.Health.Position = Vector2.new(pos.X, pos.Y + boxHeight / 2 + 5)
                        espData.Health.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth)
                    else
                        espData.Health.Visible = false
                    end

                    if State.Visual.ESPDistance then
                        espData.Distance.Visible = true
                        espData.Distance.Position = Vector2.new(pos.X, pos.Y + boxHeight / 2 + 18)
                        espData.Distance.Text = math.floor(dist) .. " studs"
                    else
                        espData.Distance.Visible = false
                    end

                    if State.Visual.ESPSnapLine then
                        espData.SnapLine.Visible = true
                        espData.SnapLine.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        espData.SnapLine.To = Vector2.new(pos.X, pos.Y)
                    else
                        espData.SnapLine.Visible = false
                    end
                else
                    for _, obj in pairs(espData) do obj.Visible = false end
                end
            end
        end
    end
end)


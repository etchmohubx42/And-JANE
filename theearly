--  HITBOX EXPANDER LOGIC — OPTIMIZED (only on change, no continue keyword)
-- ═══════════════════════════════════════════════════════════════════════════════
local OriginalHitboxes = {}
local lastHitboxSize = nil
local lastHitboxEnabled = false

RunService.RenderStepped:Connect(function()
    if State.Hitbox.Enabled then
        if not lastHitboxEnabled or lastHitboxSize ~= State.Hitbox.Size then
            -- Size changed or just enabled, update all
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character then
                    local shouldSkip = false
                    if State.Hitbox.TargetLockOnly and State.TargetLock.Enabled then
                        if plr ~= State.TargetLock.SelectedPlayer then
                            shouldSkip = true
                        end
                    end

                    if not shouldSkip then
                        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            if not OriginalHitboxes[plr] then
                                OriginalHitboxes[plr] = hrp.Size
                            end
                            hrp.Size = Vector3.new(State.Hitbox.Size, State.Hitbox.Size, State.Hitbox.Size)
                            hrp.Transparency = State.Hitbox.Visualize and State.Hitbox.Transparency or 1
                        end
                    else
                        -- Reset if was expanded
                        if OriginalHitboxes[plr] and plr.Character then
                            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                            if hrp then
                                hrp.Size = OriginalHitboxes[plr]
                                hrp.Transparency = 1
                            end
                        end
                    end
                end
            end
            lastHitboxSize = State.Hitbox.Size
            lastHitboxEnabled = true
        end
    else
        if lastHitboxEnabled then
            for plr, originalSize in pairs(OriginalHitboxes) do
                if plr.Character then
                    local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        hrp.Size = originalSize
                        hrp.Transparency = 1
                    end
                end
            end
            OriginalHitboxes = {}
            lastHitboxEnabled = false
            lastHitboxSize = nil
        end
    end
end)


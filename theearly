local function SwitchTab(tabName)
    for name, data in pairs(TabButtons) do
        if name == tabName then
            pcall(function() TweenService:Create(data.Button, TweenInfo.new(0.2), {TextColor3 = Colors.TabActive}):Play() end)
            if data.Indicator then data.Indicator.Visible = true end
            if TabContents[name] then TabContents[name].Visible = true end
        else
            pcall(function() TweenService:Create(data.Button, TweenInfo.new(0.2), {TextColor3 = Colors.TabInactive}):Play() end)
            if data.Indicator then data.Indicator.Visible = false end
            if TabContents[name] then TabContents[name].Visible = false end
        end
    end
    CurrentTab = tabName
end

for name, data in pairs(TabButtons) do
    if data.Button then
        data.Button.MouseButton1Click:Connect(function() SwitchTab(name) end)
    end
end

local function BuildTab(tabName, controls)
    local content = TabContents[tabName]
    if not content then return end
    local y = 10
    for _, control in ipairs(controls) do
        local t = control.type
        if t == "toggle" then
            CreateToggle(content, control.text, control.default, control.callback, y)
            y = y + 34
        elseif t == "slider" then
            CreateSlider(content, control.text, control.min, control.max, control.default, control.decimals, control.callback, y)
            y = y + 48
        elseif t == "dropdown" then
            CreateDropdown(content, control.text, control.options, control.default, control.callback, y)
            y = y + 34
        elseif t == "keybind" then
            CreateKeybind(content, control.text, control.default, control.callback, y)
            y = y + 34
        elseif t == "color" then
            CreateColorPicker(content, control.text, control.default, control.callback, y)
            y = y + 34
        elseif t == "header" then
            CreateSectionHeader(content, control.text, y)
            y = y + 28
        elseif t == "spacer" then
            y = y + (control.size or 10)
        elseif t == "button" then
            CreateButton(content, control.text, control.callback, y)
            y = y + 38
        elseif t == "input" then
            CreateTextInput(content, control.text, control.default, control.callback, y)
            y = y + 58
        end
    end
    content.CanvasSize = UDim2.new(0, 0, 0, y + 20)
end

